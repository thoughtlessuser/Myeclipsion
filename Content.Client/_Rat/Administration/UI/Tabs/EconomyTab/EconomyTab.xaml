<Control xmlns="https://spacestation14.io"
         xmlns:co="clr-namespace:Content.Client.UserInterface.Controls">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Horizontal">
            <Label Text="{Loc admin-menu-economy-tab-type}" />
            <OptionButton Name="CategoryOptions" HorizontalAlignment="Left" />
            <LineEdit Name="SearchLineEdit" PlaceHolder="{Loc admin-menu-economy-search}" HorizontalExpand="True"
                      SizeFlagsStretchRatio="1" />
            <Button Name="RefreshListButton" Text="{Loc admin-menu-economy-refresh}" ToggleMode="False" />
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
            <Label Name="SelectedEntryLabel" Text="{Loc admin-menu-economy-no-selection}" HorizontalExpand="True" />
            <LineEdit Name="PriceLineEdit" PlaceHolder="{Loc admin-menu-economy-price}" MinWidth="120" />
            <Button Name="SavePriceButton" Text="{Loc admin-menu-economy-save}" Disabled="True" />
        </BoxContainer>
        <Label Name="StatusLabel" Margin="0 4 0 0" />
        <co:SearchListContainer Name="SearchList" Access="Public" VerticalExpand="True" Margin="0 4 0 0" />
    </BoxContainer>
</Control>
