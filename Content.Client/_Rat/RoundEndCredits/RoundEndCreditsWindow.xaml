<DefaultWindow xmlns="https://spacestation14.io"
               Title=""
               SetSize="1920 1080"
               Resizable="False">
    <PanelContainer Name="Background" HorizontalExpand="True" VerticalExpand="True">
        <ScrollContainer Name="Scroll"
                         HorizontalExpand="True"
                         VerticalExpand="True"
                         HScrollEnabled="False"
                         VScrollEnabled="False">
            <BoxContainer Orientation="Vertical" HorizontalExpand="True"
                          HorizontalAlignment="Center">
                <Control Name="TopSpacer" MinHeight="800" />
                <BoxContainer Name="CreditsContainer" Orientation="Vertical"
                              HorizontalAlignment="Center"
                              SeparationOverride="24" />
                <Control Name="BottomSpacer" MinHeight="800" />
            </BoxContainer>
        </ScrollContainer>
    </PanelContainer>
</DefaultWindow>
