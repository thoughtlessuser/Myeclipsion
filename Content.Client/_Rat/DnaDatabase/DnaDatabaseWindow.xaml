<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:dna="clr-namespace:Content.Client._Rat.DnaDatabase"
               Title="{Loc 'dna-database-title'}"
               MinSize="400 300">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <Label Name="DescriptionLabel" StyleClasses="LabelSecondaryColor" Text="{Loc 'dna-database-ui-description'}"/>
        <Label Name="FactionLabel" StyleClasses="LabelKeyText"/>
        <Label Name="StatusLabel"/>
        <Label Name="JobsLabel" StyleClasses="LabelSecondaryColor"/>
        <Button Name="ToggleButton" Text="{Loc 'dna-database-toggle'}"/>
    </BoxContainer>
</DefaultWindow>
